# Every active (non-comment, non-blank) pattern in this file must either
# start with `**/` or contain a path separator before its last character.
# This is enforced by `test_gitignore_patterns_use_double_star` in
# test_meta_ratchets.py so that .dockerignore (which is a symlink to this
# file -- Docker reads the target) honors the same exclusions as git.
# Bare patterns like `runtime/` are gitignore-recursive but match only at
# the build context root under dockerignore syntax; the `**/` prefix
# makes both formats agree.

# Forever Claude runtime state.
# memory/ now lives at runtime/memory/ (configured via .claude/settings.json's
# autoMemoryDirectory) so the runtime-backup service backs it up alongside
# the rest of runtime/.
**/runtime/

# Sculptor local config (per-checkout, not shared).
**/.sculptor/

# Login-modal reshape mocks (design exploration, not shipped).
specs/login-modal-reshape/

# Playwright MCP session artifacts.
**/.playwright-mcp/

# tk tickets (tracker is vendored at vendor/tk; the tickets themselves are local state)
**/.tickets/

# External repos we're actively working on (e.g. mngr) live here as standalone
# clones, separate from the read-only vendor/ subtrees. See CLAUDE.md.
**/.external_worktrees/

# The generic harden worker installed into a worker's tree at provision time by
# install_worker_skills.sh (from the single source at .agents/shared/worker/).
# It is a scratch copy that must never be committed -- otherwise a worker's
# broad `git add` would carry it onto its branch and the merge would leak it
# into main. The source at .agents/shared/worker/ is not matched by this glob
# and stays tracked.
.agents/skills/*-worker/

# Byte-compiled / optimized / DLL files
**/__pycache__/
**/*.py[codz]
**/*$py.class

# C extensions
**/*.so

# Distribution / packaging
**/.Python
**/build/
**/develop-eggs/
**/dist/
**/downloads/
**/eggs/
**/.eggs/
**/lib/
**/lib64/
**/parts/
**/sdist/
**/var/
**/wheels/
share/python-wheels/
**/*.egg-info/
**/.installed.cfg
**/*.egg
**/MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
**/*.manifest
**/*.spec

# Installer logs
**/pip-log.txt
**/pip-delete-this-directory.txt

