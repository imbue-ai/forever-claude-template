FROM nixos/nix:2.34.7@sha256:bf1d938835ab96312f098fa6c2e9cab367728e0aad0646ee3e02a787c80d8fb8 AS fct-nix-profile

SHELL ["/root/.nix-profile/bin/bash", "-euo", "pipefail", "-c"]

# Nix-managed tools are installed into this profile. /root/.local/bin holds uv
# and claude; /usr/local/bin holds npm globals and small compatibility shims.
ENV FCT_NIX_PROFILE="/nix/var/nix/profiles/fct-workspace"
ENV PATH="/root/.local/bin:/usr/local/bin:${FCT_NIX_PROFILE}/bin:${FCT_NIX_PROFILE}/sbin:/root/.nix-profile/bin:/nix/var/nix/profiles/default/bin:/nix/var/nix/profiles/default/sbin:$PATH"
ENV LD_LIBRARY_PATH="${FCT_NIX_PROFILE}/lib:${FCT_NIX_PROFILE}/lib64:/usr/local/lib:/usr/lib"

# Keep in sync with agent_types.claude.version in .mngr/settings.toml and the
# default in scripts/setup_system.sh.
ARG CLAUDE_CODE_VERSION=2.1.160
ARG UV_VERSION=0.11.7
ARG MODAL_VERSION=1.4.2
ARG LATCHKEY_VERSION=2.17.1
ARG FCT_NIX_CLOSURE_MODE=verify
ENV CLAUDE_CODE_VERSION=${CLAUDE_CODE_VERSION}
ENV OPENSSL_armcap=0
ENV NPM_CONFIG_PREFIX=/usr/local

# ============================================================================
# Nix system toolchain (repo-independent).
# ============================================================================
COPY flake.nix flake.lock /tmp/fct-nix/
COPY nix/fct-workspace-env.nix /tmp/fct-nix/nix/fct-workspace-env.nix
COPY nix/fct-workspace-closure.*.txt /tmp/fct-nix/nix/
RUN nix --extra-experimental-features "nix-command flakes" build \
      --no-update-lock-file \
      --out-link "$FCT_NIX_PROFILE" \
      /tmp/fct-nix#fct-workspace-env \
    && case "$(uname -m)" in \
      x86_64) fct_nix_system=x86_64-linux ;; \
      aarch64|arm64) fct_nix_system=aarch64-linux ;; \
      *) echo "unsupported docker architecture: $(uname -m)" >&2; exit 1 ;; \
    esac \
    && expected_manifest="/tmp/fct-nix/nix/fct-workspace-closure.${fct_nix_system}.txt" \
    && mkdir -p /etc/fct-workspace \
    && nix-store -q --requisites "$FCT_NIX_PROFILE" | sort > /etc/fct-workspace/nix-closure.txt \
    && case "$FCT_NIX_CLOSURE_MODE" in \
      verify) test -f "$expected_manifest" && diff -u "$expected_manifest" /etc/fct-workspace/nix-closure.txt ;; \
      generate) true ;; \
      *) echo "unsupported FCT_NIX_CLOSURE_MODE: $FCT_NIX_CLOSURE_MODE" >&2; exit 1 ;; \
    esac

FROM fct-nix-profile AS workspace

SHELL ["/root/.nix-profile/bin/bash", "-euo", "pipefail", "-c"]

# Compatibility paths expected by mngr's Docker/SSH provider and by downloaded
# tools that assume FHS dynamic-loader locations.
RUN set -eux; \
    mkdir -p /etc/ssl/certs /etc/ssh /run/sshd /usr/lib /usr/sbin /usr/local/bin /var/empty/sshd; \
    ln -sfn /run /var/run; \
    grep -q '^sshd:' /etc/group || echo 'sshd:x:74:' >> /etc/group; \
    grep -q '^sshd:' /etc/passwd || echo 'sshd:x:74:74:Privilege-separated SSH:/var/empty/sshd:/bin/sh' >> /etc/passwd; \
    sed -i -E 's/^root:!+:/root:*:/' /etc/shadow; \
    sshd_realpath="$(readlink -f "$(command -v sshd)")"; \
    sftp_server="$(dirname "$(dirname "$sshd_realpath")")/libexec/sftp-server"; \
    test -x "$sftp_server"; \
    ln -sf "$sshd_realpath" /usr/sbin/sshd; \
    ln -sf "$sftp_server" /usr/local/bin/sftp-server; \
    ln -sf "$FCT_NIX_PROFILE/lib/libstdc++.so.6" /usr/lib/libstdc++.so.6; \
    ln -sf "$FCT_NIX_PROFILE/lib/libgcc_s.so.1" /usr/lib/libgcc_s.so.1; \
    for browser_lib in \
      libglib-2.0.so.0 \
      libgobject-2.0.so.0 \
      libnspr4.so \
      libnss3.so \
      libnssutil3.so \
      libgio-2.0.so.0 \
      libatk-1.0.so.0 \
      libdbus-1.so.3 \
      libexpat.so.1 \
      libatspi.so.0 \
      libX11.so.6 \
      libXcomposite.so.1 \
      libXdamage.so.1 \
      libXext.so.6 \
      libXfixes.so.3 \
      libXrandr.so.2 \
      libgbm.so.1 \
      libxcb.so.1 \
      libxkbcommon.so.0 \
      libudev.so.1 \
      libasound.so.2 \
      libcups.so.2 \
      libcairo.so.2 \
      libpango-1.0.so.0; do \
      browser_lib_path="$(find /nix/store -path "*/lib/$browser_lib" -print -quit)"; \
      test -n "$browser_lib_path"; \
      ln -sf "$browser_lib_path" "/usr/lib/$browser_lib"; \
    done; \
    cert_bundle="$FCT_NIX_PROFILE/etc/ssl/certs/ca-bundle.crt"; \
    test -f "$cert_bundle"; \
    ln -sf "$cert_bundle" /etc/ssl/certs/ca-certificates.crt; \
    printf '%s\n' '#!/usr/bin/env bash' 'set -euo pipefail' 'test -f /etc/ssl/certs/ca-certificates.crt' > /usr/local/bin/update-ca-certificates; \
    chmod +x /usr/local/bin/update-ca-certificates; \
    dynamic_linker="$(nix-instantiate --eval --strict -E '(import <nixpkgs> {}).stdenv.cc.bintools.dynamicLinker' | tr -d '\"')"; \
    case "$(uname -m)" in \
      x86_64) mkdir -p /lib64; ln -sf "$dynamic_linker" /lib64/ld-linux-x86-64.so.2 ;; \
      aarch64|arm64) mkdir -p /lib; ln -sf "$dynamic_linker" /lib/ld-linux-aarch64.so.1 ;; \
      *) echo "unsupported docker architecture: $(uname -m)" >&2; exit 1 ;; \
    esac; \
    ssh-keygen -A; \
    { \
      echo 'PermitRootLogin yes'; \
      echo 'PubkeyAuthentication yes'; \
      echo 'PasswordAuthentication no'; \
      echo 'KbdInteractiveAuthentication no'; \
      echo 'AuthorizedKeysFile .ssh/authorized_keys'; \
      echo 'PidFile /run/sshd/sshd.pid'; \
      echo "SetEnv FCT_NIX_PROFILE=$FCT_NIX_PROFILE LD_LIBRARY_PATH=$FCT_NIX_PROFILE/lib:$FCT_NIX_PROFILE/lib64:/usr/local/lib:/usr/lib"; \
      echo "Subsystem sftp $sftp_server"; \
    } > /etc/ssh/sshd_config; \
    /usr/sbin/sshd -t

# uv and Claude Code are pinned to match the existing Debian Dockerfile.
RUN curl -LsSf "https://astral.sh/uv/${UV_VERSION}/install.sh" | sh
RUN curl -fsSL https://claude.ai/install.sh > /tmp/install_claude.sh \
    && bash /tmp/install_claude.sh "${CLAUDE_CODE_VERSION}" \
    && test -x /root/.local/bin/claude

# Make runtime PATH and /mngr/env behavior match scripts/setup_system.sh.
RUN set -eux; \
    mkdir -p /etc/profile.d; \
    printf '%s\n' \
      "export FCT_NIX_PROFILE=\"${FCT_NIX_PROFILE}\"" \
      "export PATH=\"/root/.local/bin:/usr/local/bin:${FCT_NIX_PROFILE}/bin:${FCT_NIX_PROFILE}/sbin:\$PATH\"" \
      "export LD_LIBRARY_PATH=\"${FCT_NIX_PROFILE}/lib:${FCT_NIX_PROFILE}/lib64:/usr/local/lib:/usr/lib:\${LD_LIBRARY_PATH:-}\"" \
      > /etc/profile.d/fct_path.sh; \
    echo 'export FCT_NIX_PROFILE="'"$FCT_NIX_PROFILE"'"' >> /root/.bashrc; \
    echo 'PATH="/root/.local/bin:/usr/local/bin:'"$FCT_NIX_PROFILE"'/bin:'"$FCT_NIX_PROFILE"'/sbin:$PATH"' >> /root/.bashrc; \
    echo 'export LD_LIBRARY_PATH="'"$FCT_NIX_PROFILE"'/lib:'"$FCT_NIX_PROFILE"'/lib64:/usr/local/lib:/usr/lib:${LD_LIBRARY_PATH:-}"' >> /root/.bashrc; \
    printf '%s\n' 'if [ -f /mngr/env ]; then set -a; . /mngr/env; set +a; fi' >> /root/.bashrc

# Pre-seed github.com SSH host keys so git operations do not block.
RUN set -eux; \
    mkdir -p /root/.ssh; \
    chmod 700 /root/.ssh; \
    ssh-keyscan -t rsa,ecdsa,ed25519 github.com >> /root/.ssh/known_hosts; \
    chmod 600 /root/.ssh/known_hosts

# latchkey (gateway CLI) and modal (python tool).
RUN npm install -g "latchkey@${LATCHKEY_VERSION}" \
    && uv tool install "modal==${MODAL_VERSION}"

# Safety-net symlinks: /code -> /mngr/code and /worktree -> /mngr/worktree.
RUN ln -s /mngr/code /code && ln -s /mngr/worktree /worktree

# ============================================================================
# Pre-COPY manifest layer. Mirrors the existing Dockerfile so dependency work
# caches against manifests instead of application source.
# ============================================================================
WORKDIR /mngr/code/

COPY pyproject.toml uv.lock /mngr/code/
COPY libs/app_watcher/pyproject.toml /mngr/code/libs/app_watcher/pyproject.toml
COPY libs/bootstrap/pyproject.toml /mngr/code/libs/bootstrap/pyproject.toml
COPY libs/cloudflare_tunnel/pyproject.toml /mngr/code/libs/cloudflare_tunnel/pyproject.toml
COPY libs/runtime_backup/pyproject.toml /mngr/code/libs/runtime_backup/pyproject.toml
COPY libs/telegram_bot/pyproject.toml /mngr/code/libs/telegram_bot/pyproject.toml
COPY libs/web_server/pyproject.toml /mngr/code/libs/web_server/pyproject.toml
COPY apps/system_interface/pyproject.toml /mngr/code/apps/system_interface/pyproject.toml

COPY vendor/mngr/libs/imbue_common/pyproject.toml /mngr/code/vendor/mngr/libs/imbue_common/pyproject.toml
COPY vendor/mngr/libs/mngr/pyproject.toml /mngr/code/vendor/mngr/libs/mngr/pyproject.toml
COPY vendor/mngr/libs/mngr_claude/pyproject.toml /mngr/code/vendor/mngr/libs/mngr_claude/pyproject.toml
COPY vendor/mngr/libs/mngr_modal/pyproject.toml /mngr/code/vendor/mngr/libs/mngr_modal/pyproject.toml
COPY vendor/mngr/libs/mngr_wait/pyproject.toml /mngr/code/vendor/mngr/libs/mngr_wait/pyproject.toml
COPY vendor/mngr/libs/resource_guards/pyproject.toml /mngr/code/vendor/mngr/libs/resource_guards/pyproject.toml
COPY vendor/mngr/libs/concurrency_group/pyproject.toml /mngr/code/vendor/mngr/libs/concurrency_group/pyproject.toml

COPY apps/system_interface/frontend/package.json apps/system_interface/frontend/package-lock.json /mngr/code/apps/system_interface/frontend/

COPY scripts/install_dependencies.sh /usr/local/bin/fct-install-dependencies
RUN chmod +x /usr/local/bin/fct-install-dependencies && fct-install-dependencies

# ============================================================================
# End pre-COPY manifest layer. Source-changing layers begin below.
# ============================================================================

COPY . /mngr/code/

RUN bash /mngr/code/scripts/build_workspace.sh

RUN mv /mngr/code /docker_build_code

COPY scripts/fct_seed.sh /usr/local/bin/fct-seed
RUN chmod +x /usr/local/bin/fct-seed
