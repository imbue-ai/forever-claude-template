{
  "autoMemoryDirectory": "runtime/memory",
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv sync --all-packages"
          },
          {
            "type": "command",
            "command": "./scripts/claude_update_plugin.sh"
          },
          {
            "type": "command",
            "command": "${MNGR_AGENT_WORK_DIR:-.}/scripts/ensure_tk_on_path.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${MNGR_AGENT_WORK_DIR:-.}/scripts/claude_prevent_commit_rewrite.sh"
          },
          {
            "type": "command",
            "command": "${MNGR_AGENT_WORK_DIR:-.}/scripts/claude_tk_standalone.sh"
          },
          {
            "type": "command",
            "command": "${MNGR_AGENT_WORK_DIR:-.}/scripts/claude_require_steps_pretool.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${MNGR_AGENT_WORK_DIR:-.}/scripts/claude_open_tickets_reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$MNGR_CLAUDE_SUBAGENT_PROXY_CHILD\" ] && exit 0; [ -e .git ] || { echo \"Be sure to return to the repo root when you finish! Otherwise the other stop hooks cannot run correctly.\" >&2; exit 2; }"
          },
          {
            "type": "command",
            "command": "[ -n \"$MNGR_CLAUDE_SUBAGENT_PROXY_CHILD\" ] && exit 0; ${MNGR_AGENT_WORK_DIR:-.}/scripts/claude_open_tickets_stop_nudge.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "imbue-code-guardian": {
      "source": {
        "source": "github",
        "repo": "imbue-ai/code-guardian"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    }
  },
  "enabledPlugins": {
    "imbue-code-guardian@imbue-code-guardian": true,
    "frontend-design@claude-code-plugins": true
  },
  "model": "opus[1m]",
  "effortLevel": "high",
  "statusLine": {
    "type": "command",
    "command": "${MNGR_AGENT_WORK_DIR:-.}/scripts/claude_status_line.sh"
  }
}
